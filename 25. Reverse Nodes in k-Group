import java.util.*;
 class listnode{
    int val;
    listnode next;
    listnode(int val){
        this.val=val;
        this.next=null;
    }
}


class solution{
public listnode reverseknode(listnode head, int k){
    
    
        if (head == null || k == 1)
            return head;

    int totalnode=0;
    listnode dummy= new listnode(0);
    dummy.next=head;
    listnode prev= dummy;
    
    listnode temp=head;
    while(temp!=null){
        totalnode++;
        temp=temp.next;
    }
    
    while(totalnode>=k){
        listnode curr=prev.next;
        listnode next=curr.next;
        
        for(int i=1;i<k;i++){
            curr.next=next.next;
            next.next= prev.next;
            prev.next=next;
            next=curr.next;
        }
        prev=curr;
        totalnode = totalnode-k;
    }
    return dummy.next;
}
}

public class Main{
    public static void printout(listnode head){
        while(head!=null){
            System.out.print(head.val);
            head=head.next;
        }
    }
    public static void main(String[] args){
        listnode l=new listnode(1);
        l.next=new listnode(2);
        l.next.next=new listnode(3);
        l.next.next.next=new listnode(4);
        l.next.next.next.next=new listnode(5);
        
        int k=2;
        
        solution obj= new solution();
        listnode res= obj.reverseknode(l,k);
        printout(res);
    }
}
