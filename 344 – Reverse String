import java.util.*;
public class Main{
    public static void main(String[] args){
        Scanner in= new Scanner(System.in);
        
      String word=in.nextLine();
      char [] arr= word.toCharArray();
      
      
      int left=0;
      int right=word.length()-1;
      
      while(left<right){
          char temp=arr[left];
          arr[left]=arr[right];
          arr[right]=temp;
          
          left++;
          right--;
      }
      
     String ans= new String(arr);
     
     System.out.println(ans);
      
    }
}
