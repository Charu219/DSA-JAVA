import java.util.*;
class listnode{
    int val;
    listnode next;
    
    listnode(int val){
        this.val=val;
        this.next=null;
    }
    }
    
    class solution{
        public listnode reverselist2(listnode head,int l,int r){
            listnode dummy= new listnode(0);
            listnode prev=dummy;
            
            dummy.next=head;
            for(int i=1;i<l;i++){
                prev=prev.next;
            }
            
            listnode curr=prev.next;
            
            for(int i=0;i<r-l;i++){
                listnode temp=curr.next;
                curr.next=temp.next;
                temp.next=prev.next;
                prev.next=temp;
            }
            return dummy.next;
        }
    }
    
    public class Main{
        
        public static void printout(listnode head){
            while(head!=null){
                System.out.print(head.val+" ");
                head=head.next;
            }
        }
        public static void main(String[] args){
            listnode l=new listnode(1);
            l.next=new listnode(2);
            l.next.next=new listnode(3);
            l.next.next.next=new listnode(4);
            l.next.next.next.next=new listnode(5);
            
            int left=2;
            int r=4;
            
            solution obj= new solution();
            listnode res=obj.reverselist2(l,left,r);
            printout(res);
            
        }
    }
