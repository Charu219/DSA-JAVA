import java.util.*;
public class Main{
    public static void main(String[] args){
        Scanner in= new Scanner(System.in);
        
        String str=in.nextLine();
        str=str.trim();
        String [] word= str.split("\\s+");
        
        String res="";
        for(int i=word.length-1;i>=0;i--){
            res+=word[i];
            
            if(i!=0){
                res+=" ";
            }
            
        }
        System.out.println(res);
        
    }
}
