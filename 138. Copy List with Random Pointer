import java.util.*;
class listnode{
    int val;
    listnode next;
    listnode random;
    
    listnode(int val){
        this.val=val;
        this.next=null;
        this.random=null;
    }
}
class solution{
    public listnode randompointer(listnode head){
        if(head==null)
           return null;
        
        listnode temp=head;
        
        //insert copy;
        while(temp!=null){
            listnode copy= new listnode(temp.val);
            copy.next=temp.next;
            temp.next=copy;
            temp=copy.next;
        }
        
        temp=head;
        
        //assign random pointers
        while(temp!=null){
            if(temp.random!=null){
                temp.next.random=temp.random.next;
            }
            temp=temp.next.next;
        }
        
        //seperate again
        temp=head;
        listnode dummy=new listnode(0);
        listnode copynode=dummy;
        while(temp!=null){
            listnode copy = temp.next;
            
            copynode.next=copy;
            copynode=copy;
            
            temp.next=copy.next;
            temp=temp.next;
        }
        
        return dummy.next;
    }
}

public class Main{
    public static void printout(listnode head){
        while(head!=null){
            int randomValue = -1;
            
            if(head.random != null)
                randomValue = head.random.val;

            System.out.println(
                "Node: " + head.val +
                "  Random: " + randomValue
            );

            head = head.next;
        }
    }
    public static void main(String[] args){
        listnode l=new listnode(1);
        l.next=new listnode(2);
        l.next.next=new listnode(3);
        l.next.next.next=new listnode(4);
        l.next.next.next.next=new listnode(5);
        
        
        l.random = l.next.next;        // 1 → 3
        l.next.random = l;             // 2 → 1
        l.next.next.random = l.next.next.next.next; // 3 → 5
        l.next.next.next.random = null; // 4 → null
        l.next.next.next.next.random = l.next; // 5 → 2

        
        solution obj= new solution();
        listnode res= obj.randompointer(l);
        printout(res);
        
    }
}
