import java.util.*;
public class Main{
    public static void main(String[] args){
        Scanner in = new Scanner(System.in);
        int n= in.nextInt();
        int [] arr= new int[n];
        int [] choco=new int[n];
        
        for(int i=0;i<n;i++){
            arr[i]=in.nextInt();
        }
        
        Arrays.fill(choco,1);
        for(int i=1;i<n;i++){
            if(arr[i]>arr[i-1]){
                choco[i]=choco[i-1]+1;
            }        
            
        }
        
        for(int i=n-2;i>=0;i--){
            if(arr[i]>arr[i+1]){
                choco[i]=Math.max(choco[i],choco[i+1]+1);
            }
        }
        
        int tot=0;
        
        for(int c:choco){
            tot+=c;
        }
        System.out.println(tot);
    }
}
