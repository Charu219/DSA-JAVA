import java.util.*;
public class Main{
    public static void main(String[] args){
        Scanner in = new Scanner(System.in);
        int n=in.nextInt();
        int [] nums= new int[n];
        
        for(int i=0;i<n;i++){
            nums[i]=in.nextInt();
        }
        int profit=0;
        
        for(int i=1;i<nums.length;i++){
            if(nums[i]>nums[i-1]){
                profit+= nums[i]-nums[i-1];
            }
        }
        System.out.print(profit);
    }
}
